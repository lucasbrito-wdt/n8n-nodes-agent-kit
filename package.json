{
  "name": "n8n-nodes-agent-kit",
  "version": "0.1.23",
  "description": "n8n node cluster: AgentKit, SkillLoader, AgentMemory, McpGateway",
  "license": "MIT",
  "keywords": [
    "n8n-community-node-package"
  ],
  "author": {
    "name": "luquinhasbrito"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --watch --project tsconfig.json",
    "test": "jest",
    "lint": "eslint nodes credentials utils --ext .ts"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 2,
    "credentials": [
      "dist/credentials/OpenRouterApi.credentials.js",
      "dist/credentials/GithubSkillsApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/AgentKit/AgentKit.node.js",
      "dist/nodes/SkillLoader/SkillLoader.node.js",
      "dist/nodes/AgentMemory/AgentMemory.node.js",
      "dist/nodes/McpGateway/McpGateway.node.js",
      "dist/nodes/SubAgentKit/SubAgentKit.node.js",
      "dist/nodes/OrchestratorKit/OrchestratorKit.node.js"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "gray-matter": "^4.0.3",
    "openai": "^4.77.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^9.4.3"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "n8n-workflow": "^1.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.4.0"
  }
}
